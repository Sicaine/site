---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import WappenHero from '../components/WappenHero.astro';
import LinksSection from '../components/LinksSection.astro';
---

<Layout title="uhu.sh - Family Homepage" description="uhu.sh family homepage with Familienwappen">
  <Header />
  <main>
    <WappenHero />
    <LinksSection />
  </main>
  <footer class="footer">
    <div class="container">
      <p>&copy; 2026 uhu.sh. All rights reserved.</p>
    </div>
  </footer>
</Layout>

<style>
  .footer {
    background-color: var(--text-dark);
    color: white;
    text-align: center;
    padding: 2rem 0;
    margin-top: 2rem;
  }

  .footer p {
    margin: 0;
    color: inherit;
  }
</style>
