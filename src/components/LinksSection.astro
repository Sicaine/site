---
import links from '../data/links.json';
---

<section class="links-section">
  <div class="container">
    <h2>Services & Projects</h2>
    <div class="links-grid">
      {
        links.services.map((service) => (
          <a href={service.url} class="link-card" target="_blank" rel="noopener noreferrer">
            <div class="card-icon">{service.icon}</div>
            <h3 class="card-title">{service.name}</h3>
            <p class="card-description">{service.description}</p>
          </a>
        ))
      }
      {
        links.projects.map((project) => (
          <a href={project.url} class="link-card" target="_blank" rel="noopener noreferrer">
            <div class="card-icon">{project.icon}</div>
            <h3 class="card-title">{project.name}</h3>
            <p class="card-description">{project.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .links-section {
    padding: 4rem 0;
    background-color: white;
  }

  .links-section h2 {
    margin-top: 0;
    margin-bottom: 2rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 2rem;
    background-color: var(--bg-white);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    text-align: center;
    transition: all 0.3s ease;
    color: inherit;
  }

  .link-card:hover {
    border-color: var(--olive-green);
    box-shadow: 0 4px 12px rgba(107, 123, 59, 0.15);
    transform: translateY(-4px);
    color: inherit;
  }

  .card-icon {
    font-size: 2.5rem;
    line-height: 1;
  }

  .card-title {
    font-family: 'EB Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-dark);
    margin: 0;
  }

  .card-description {
    font-size: 0.95rem;
    color: var(--text-light);
    margin: 0;
  }

  @media (max-width: 768px) {
    .links-section {
      padding: 2.5rem 0;
    }

    .links-grid {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .link-card {
      padding: 1.5rem;
    }

    .card-icon {
      font-size: 2rem;
    }

    .card-title {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
