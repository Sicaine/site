---

<section class="hero">
  <div class="hero-content">
    <picture class="wappen-image">
      <source srcset="/wappen/hero.webp" type="image/webp" />
      <img src="/wappen/hero.png" alt="Familienwappen - Wurzeln schlagen, weite wagen" width="600" height="338" loading="eager" />
    </picture>
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
    min-height: 500px;
    background: linear-gradient(135deg, rgba(107, 123, 59, 0.05) 0%, rgba(212, 175, 55, 0.05) 100%);
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 700px;
  }

  .wappen-image {
    display: block;
    width: 100%;
    max-width: 600px;
    animation: fadeIn 0.8s ease-in-out;
  }

  .wappen-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 2rem 1rem;
      min-height: 400px;
    }

    .wappen-image {
      max-width: 450px;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 1.5rem 1rem;
      min-height: 350px;
    }

    .wappen-image {
      max-width: 350px;
    }
  }
</style>
